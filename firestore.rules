rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function profilePath() {
      return /databases/$(database)/documents/pmcUsuarios/$(request.auth.uid);
    }

    function profileExists() {
      return signedIn() && exists(profilePath());
    }

    function profile() {
      return get(profilePath()).data;
    }

    function active() {
      return profileExists() && profile().ativo == true;
    }

    function isAdmin() {
      return active() && profile().perfil == 'admin';
    }

    function isBuyer() {
      return active() && profile().perfil in ['compras', 'gestor', 'admin'];
    }

    function isMainAdminEmail() {
      return signedIn() && request.auth.token.email == 'a.camilo@fiemg.com.br';
    }

    match /pmcUsuarios/{uid} {
      // Cada usuário pode consultar o próprio perfil. O administrador pode consultar todos.
      allow get: if signedIn() && (request.auth.uid == uid || isAdmin());
      allow list: if isAdmin();

      // Cadastro público sempre cria perfil solicitante e ativo.
      // O e-mail principal pode criar o primeiro administrador.
      allow create: if signedIn()
        && request.auth.uid == uid
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.ativo == true
        && (
          request.resource.data.perfil == 'solicitante'
          || (isMainAdminEmail() && request.resource.data.perfil == 'admin')
        );

      // Perfis só podem ser alterados pelo administrador.
      allow update: if isAdmin()
        && request.resource.data.email == resource.data.email;

      allow delete: if false;
    }

    match /pmcSolicitacoes/{id} {
      allow create: if active()
        && request.resource.data.solicitanteUid == request.auth.uid
        && request.resource.data.solicitanteEmail == request.auth.token.email;

      allow read: if active();
      // Compras/gestão atualizam o fluxo. O solicitante só pode editar ou enviar o próprio rascunho.
      allow update: if isBuyer() || (active()
        && resource.data.solicitanteUid == request.auth.uid
        && resource.data.status == 'Rascunho'
        && request.resource.data.solicitanteUid == resource.data.solicitanteUid
        && request.resource.data.solicitanteEmail == resource.data.solicitanteEmail);
      allow delete: if isAdmin();
    }

    match /pmcConfig/{id} {
      allow read: if active();
      allow create, update: if isAdmin();
      allow delete: if false;
    }

    match /pmcContadores/{id} {
      allow read: if active();
      allow create: if active() && id == 'pedidos' && request.resource.data.ultimo == 1;
      allow update: if active() && id == 'pedidos'
        && request.resource.data.ultimo == resource.data.ultimo + 1;
      allow delete: if false;
    }

    match /pmcHistorico/{id} {
      allow read: if active();
      allow create: if active();
      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
